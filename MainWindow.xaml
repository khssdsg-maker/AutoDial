<Window x:Class="AutoDial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="宽带自动拨号" Height="680" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5"
        FontFamily="Microsoft YaHei"
        Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="宽带自动拨号" FontSize="24" FontWeight="Bold" 
                   Foreground="#1A1A2E" Margin="0,0,0,16"/>

        <!-- Account List Card -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="账号列表" Style="{StaticResource SectionTitle}"/>
                
                <ListBox Grid.Row="1" x:Name="lstAccounts" Height="90" 
                         FontSize="14" BorderThickness="0"
                         Background="White" Foreground="#333"
                         SelectionChanged="lstAccounts_SelectionChanged"/>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel>
                        <Button Content="新增" Style="{StaticResource ButtonSecondary}" Click="BtnAdd_Click" Margin="0,0,6,0"/>
                        <Button Content="删除" Style="{StaticResource ButtonSecondary}" Click="BtnDelete_Click" Margin="0,0,6,0"/>
                        <Button Content="导入" Style="{StaticResource ButtonSecondary}" Click="BtnImport_Click" Margin="0,0,6,0"/>
                        <Button Content="导出" Style="{StaticResource ButtonSecondary}" Click="BtnExport_Click"/>
                    </WrapPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="创建系统连接" Style="{StaticResource ButtonSecondary}" 
                                Click="BtnCreateConnection_Click" Background="#FF9800" Foreground="White" Margin="0,0,6,0"/>
                        <Button Content="删除系统连接" Style="{StaticResource ButtonSecondary}" 
                                Click="BtnDeleteConnection_Click" Foreground="#F44336"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Edit Fields Card -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="连接名称" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtName" Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Grid.Row="2" Text="用户名" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtUser" Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Grid.Row="4" Text="密码" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="txtPass" Style="{StaticResource TextBoxStyle}"/>
            </Grid>
        </Border>

        <!-- Settings Card -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="设置" Style="{StaticResource SectionTitle}"/>
                
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <CheckBox x:Name="chkAutoDial" Content="开机自动拨号" Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="chkSilent" Content="静默拨号" Style="{StaticResource CheckBoxStyle}"/>
                    <CheckBox x:Name="chkAutoReconnect" Content="断线自动重连" Style="{StaticResource CheckBoxStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom Section -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Status -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" x:Name="statusDot" Width="12" Height="12" Fill="#9E9E9E" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" x:Name="lblStatus" Text="未连接" FontSize="14" 
                               Foreground="#666666" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" x:Name="lblOnlineTime" Text="--:--:--" FontSize="13" 
                               Foreground="#999999" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="拨号连接" Style="{StaticResource ButtonPrimary}" 
                        x:Name="btnDial" Click="BtnDial_Click" Margin="0,0,10,0" Width="140" Height="45"/>
                <Button Content="断开连接" Style="{StaticResource ButtonDanger}" 
                        x:Name="btnDisconnect" Click="BtnDisconnect_Click" Width="140" Height="45"/>
            </StackPanel>

            <!-- Save -->
            <Button Grid.Row="4" Content="保存设置" Style="{StaticResource ButtonPrimary}" 
                    x:Name="btnSave" Click="BtnSave_Click" 
                    HorizontalAlignment="Center" Background="#4CAF50" Width="200" Height="42"/>
        </Grid>
    </Grid>
</Window>